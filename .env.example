# ============================================================
# ClipMind Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------

# Google Gemini API key (get one at https://aistudio.google.com/)
CLIPMIND_GEMINI_API_KEY=

# Absolute path to your video source directory on the host machine
CLIPMIND_VIDEO_DIR=/path/to/your/videos

# ----------------------------------------------------------
# OPTIONAL — Media directories
# ----------------------------------------------------------

# Absolute path to your photo source directory (for HEIC/JPG import)
# CLIPMIND_PHOTO_DIR=/path/to/your/photos

# Absolute path to your music library on the host machine
# CLIPMIND_MUSIC_DIR=/path/to/your/music

# ----------------------------------------------------------
# OPTIONAL — AI model
# ----------------------------------------------------------

# Gemini model to use for video analysis (default: gemini-2.5-flash)
# CLIPMIND_GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------
# OPTIONAL — CapCut Mate integration (export to JianYing / CapCut)
# ----------------------------------------------------------

# CapCut Mate API base URL (if you run CapCut Mate locally)
# CLIPMIND_CAPCUT_MATE_URL=http://host.docker.internal:30000/openapi/capcut-mate/v1

# Host path root exposed to CapCut Mate's file server (parent of CLIPMIND_VIDEO_DIR)
# CLIPMIND_FILE_SERVER_ROOT=/path/to/media/root

# ----------------------------------------------------------
# OPTIONAL — Advanced
# ----------------------------------------------------------

# Comma-separated list of allowed CORS origins (default: http://localhost:3000)
# CLIPMIND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database URL (default: SQLite at data/clipmind.db)
# CLIPMIND_DATABASE_URL=sqlite:///./data/clipmind.db
